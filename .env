# Base defaults — overridden by .env.dev or .env.prod based on ENVIRONMENT.
ENVIRONMENT=dev

# Session
SESSION_DURATION_MINUTES=30
SESSION_CYCLE_MINUTES=15
SESSION_PERSPECTIVE=third

# Model — litellm format: provider/model for non-default providers
MODEL_PROVIDER=anthropic
MODEL_NAME=claude-sonnet-4-5
# Mode: 'instruct' uses chat template (system+user). 'base' sends buffer
# directly as raw completion — for non-chat-tuned base models.
MODEL_MODE=instruct

# Sampling
SAMPLING_BASE_TEMP=1.3
SAMPLING_TEMP_MIN=0.85
SAMPLING_TEMP_MAX=1.75
SAMPLING_TOP_P=0.97
SAMPLING_MAX_TOKENS_PER_STEP=120
SAMPLING_CONTEXT_WINDOW_TOKENS=1000
# REM-phase peak-temperature multiplier of (temp_max - base_temp) above
# base_temp. 0.75 is the original sampler.py value; raise to 1.0+ for base
# models that benefit from a higher peak.
SAMPLING_REM_PEAK_FRACTION=0.75
# Register-stickiness metric (Change 13, exploratory): n-gram similarity of
# adjacent halves of the recent buffer. Disabled by default — enable for
# A/B testing.
STICKINESS_ENABLED=false
STICKINESS_THRESHOLD=0.5
STICKINESS_PATIENCE=3
# Phase-conditional override (token-equivalents; 1 tok ≈ 4 chars).
# Falls back to SAMPLING_CONTEXT_WINDOW_TOKENS if a phase value is missing.
SAMPLING_CONTEXT_WINDOW_DRIFT=800
SAMPLING_CONTEXT_WINDOW_LIGHT=1000
SAMPLING_CONTEXT_WINDOW_DEEP=1400
SAMPLING_CONTEXT_WINDOW_REM=600
SAMPLING_CONTEXT_WINDOW_SURFACE=1000

# Injection
INJECTION_BASE_INTERVAL_STEPS=5
INJECTION_STALL_THRESHOLD=0.35
INJECTION_JITTER=0.4
# Visibility: 'visible' appends fragment to buffer immediately (model sees it
# next gen); 'deferred' delays one step so it lands as ambient drift.
INJECTION_MODE=visible

# Phase-conditional source weights — order: day,world,latent
# Phase 2 spec: world events concentrated in surface/drift; deep/rem fed
# almost entirely by latent substrate.
INJECTION_WEIGHTS_DRIFT=0.20,0.30,0.50
INJECTION_WEIGHTS_LIGHT=0.30,0.20,0.50
INJECTION_WEIGHTS_DEEP=0.15,0.05,0.80
INJECTION_WEIGHTS_REM=0.10,0.00,0.90
INJECTION_WEIGHTS_SURFACE=0.30,0.40,0.30

# Corpus
CORPUS_DAY_RESIDUE_PATH=./corpus/today/
CORPUS_WORLD_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://feeds.reuters.com/reuters/topNews,https://hnrss.org/frontpage
# Refusal-trigger filter for RSS items. Auto-disabled when MODEL_MODE=base.
WORLD_REFUSAL_FILTER_ENABLED=true
WORLD_BLOCKLIST_PATH=./data/world_blocklist.txt
# Strip URLs, datelines, metadata labels from RSS fragments before injection.
WORLD_SANITIZE_FRAGMENTS=true
# Topical-drift blocklist — patterns that trigger contamination recovery
# when produced by the model itself. Independent of MODEL_MODE.
TOPICAL_BLOCKLIST_PATH=./data/topical_blocklist.txt
CORPUS_LATENT_PATH=./corpus/latent/
CORPUS_LATENT_CHUNK_CHARS=280

# Logging
LOG_DB_PATH=./dreams.db
LOG_ECHO_TO_STDOUT=true

# Self-state thread (exploratory): on phase transition, runs an extra LLM
# call to summarize recent dream-text and prepends it to the system prompt.
SELF_STATE_ENABLED=false

# Accretion: build up the latent corpus from each session.
#   fixations/       — online captures of the buffer when stickiness fires
#   phase-summaries/ — per-phase self-state checkpoints (needs SELF_STATE_ENABLED=true)
#   sessions/        — post-session distillations via one extra LLM call
#   preserved/       — manual, hand-curated material (no auto-write)
# Tier weights live in corpus/latent/weights.txt (fixations 0.1,
# phase-summaries 0.3, sessions 0.5, preserved 1.0). FIFO caps below trim
# oldest auto-written files at session end so the substrate doesn't grow
# unbounded.
ACCRETION_ENABLED=false
ACCRETION_FIXATIONS_MAX=200
ACCRETION_DISTILLATIONS_MAX=100
ACCRETION_PHASE_SUMMARIES_MAX=300
